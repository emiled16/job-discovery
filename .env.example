# Frontend
FRONTEND_PORT=3000
NEXT_TELEMETRY_DISABLED=1
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
API_INTERNAL_BASE_URL=http://api:8000

# API
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DATABASE_URL=postgresql+psycopg://job_discovery:job_discovery@postgres:5432/job_discovery
REDIS_URL=redis://redis:6379/0
API_STARTUP_SEED_MODE=full

# Worker
WORKER_BROKER_URL=redis://redis:6379/0
WORKER_RESULT_BACKEND=redis://redis:6379/1
WORKER_DATABASE_URL=postgresql+psycopg://job_discovery:job_discovery@postgres:5432/job_discovery
WORKER_HTTP_TIMEOUT_SECONDS=15

# Scheduler
SCHEDULER_BROKER_URL=redis://redis:6379/0
SCHEDULER_RESULT_BACKEND=redis://redis:6379/1
SCHEDULER_SYNC_INTERVAL_SECONDS=14400
SCHEDULER_TIMEZONE=UTC

# Infrastructure
POSTGRES_DB=job_discovery
POSTGRES_USER=job_discovery
POSTGRES_PASSWORD=job_discovery
POSTGRES_PORT=5432
REDIS_PORT=6379
